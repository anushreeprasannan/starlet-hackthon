*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:#f2f2f2;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.container{
    width:340px;
    background:white;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0px 10px 25px rgba(0,0,0,.15);
}

.top{
    text-align:center;
    padding:40px 30px;
}

.logo{
    width:65px;
    height:65px;
    background:#0f52d6;
    color:white;
    border-radius:50%;
    display:flex;
    justify-content:center;
    align-items:center;
    margin:auto;
    font-size:30px;
    margin-bottom:15px;
}

.top h1{
    color:#0f52d6;
    font-size:28px;
    font-weight:700;
}

.top p{
    color:#777;
    font-size:12px;
    letter-spacing:2px;
}

.form{
    background:#fafafa;
    padding:30px;
}

.inputBox{
    margin-bottom:20px;
}

label{
    display:block;
    color:#777;
    font-size:12px;
    margin-bottom:8px;
    font-weight:600;
    text-transform:uppercase;
}

.inputField{
    display:flex;
    align-items:center;
    border-bottom:2px solid #ddd;
    padding-bottom:8px;
}

.inputField span{
    margin-right:10px;
    font-size:18px;
}

.inputField input{
    width:100%;
    border:none;
    outline:none;
    background:none;
    font-size:15px;
}

button{
    width:100%;
    padding:14px;
    border:none;
    background:#0f52d6;
    color:white;
    font-size:18px;
    font-weight:600;
    border-radius:30px;
    cursor:pointer;
    transition:.3s;
}

button:hover{
    background:#003db5;
}

.register{
    display:block;
    text-align:center;
    margin-top:20px;
    color:#0f52d6;
    text-decoration:none;
    font-size:13px;
    font-weight:600;
}